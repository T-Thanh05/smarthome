// LOGIC CHUYỂN TAB 
// ==========================================
function switchTab(tabId) {
    document.querySelectorAll('.tab-content').forEach(tab => {
        tab.style.display = 'none';
    });

    const targetTab = document.getElementById('tab-' + tabId);
    if(targetTab) {
        targetTab.style.display = 'block';
    }

    document.querySelectorAll('.menu-links a').forEach(link => link.classList.remove('active'));
    const activeLink = document.getElementById('menu-' + tabId);
    if(activeLink) activeLink.classList.add('active');

    closeMenu();

    if(tabId === 'history') {
        loadHistoryData();
    } 
    else if (tabId === 'schedule') {
        const selectDev = document.getElementById('scheduleDevice');
        selectDev.innerHTML = '';
        if (localDevices.length === 0) {
            selectDev.innerHTML = `<option value="">Chưa có thiết bị nào</option>`;
        } else {
            localDevices.forEach(dev => { 
                selectDev.innerHTML += `<option value="${dev.id}">${dev.name}</option>`; 
            });
        }
    }
    else if (tabId === 'users') {
        fetchUsers();
    }
}

// --- LOGIC LẤY LỊCH SỬ CẢM BIẾN ---
async function loadHistoryData() {
    const tbody = document.getElementById('history-table-body');
    tbody.innerHTML = '<tr><td colspan="4" style="text-align:center; padding: 20px;">Đang tải dữ liệu từ MySQL... <i class="fas fa-spinner fa-spin"></i></td></tr>';

    try {
        const response = await fetch('/api/history');
        const data = await response.json();
        
        tbody.innerHTML = '';
        if(data.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" style="text-align:center; padding: 20px;">Chưa có dữ liệu nào được ghi nhận.</td></tr>';
            return;
        }

        data.forEach(row => {
            const dateObj = new Date(row.timestamp);
            const timeString = dateObj.toLocaleString('vi-VN');
            
            let icon = ''; let unit = '';
            if(row.sensor_type === 'temperature') { icon = '<span style="color:#ff3333"><i class="fas fa-temperature-half"></i> Nhiệt độ</span>'; unit = '°C'; }
            if(row.sensor_type === 'humidity') { icon = '<span style="color:#0088cc"><i class="fas fa-droplet"></i> Độ ẩm</span>'; unit = '%'; }
            if(row.sensor_type === 'gas') { icon = '<span style="color:#ff7300"><i class="fas fa-fire"></i> Khí Gas</span>'; unit = ''; }

            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td style="padding: 12px; border-bottom: 1px solid rgba(128,128,128,0.1);">#${row.id}</td>
                <td style="padding: 12px; border-bottom: 1px solid rgba(128,128,128,0.1); font-weight: bold;">${icon}</td>
                <td style="padding: 12px; border-bottom: 1px solid rgba(128,128,128,0.1); color: var(--primary); font-weight: bold;">${row.value} ${unit}</td>
                <td style="padding: 12px; border-bottom: 1px solid rgba(128,128,128,0.1); font-size: 13px; color: var(--text-sub);">${timeString}</td>
            `;
            tbody.appendChild(tr);
        });
    } catch (error) {
        tbody.innerHTML = '<tr><td colspan="4" style="text-align:center; color: red; padding: 20px;">Lỗi kết nối Cơ sở dữ liệu!</td></tr>';
    }
}


// --- GIAO DIỆN CHUNG & MENU ---
document.getElementById('langToggle').addEventListener('click', () => { 
    currentLang = currentLang === 'vi' ? 'en' : 'vi'; 
    renderDevices(); 
});
document.getElementById('themeToggle').addEventListener('click', () => { document.body.classList.toggle('dark-mode'); });
const sideMenu = document.getElementById('sideMenu');
const menuOverlay = document.getElementById('menuOverlay');

function openMenu() { sideMenu.classList.add('active'); menuOverlay.classList.add('active'); }
function closeMenu() { sideMenu.classList.remove('active'); menuOverlay.classList.remove('active'); }
document.getElementById('menuToggle').addEventListener('click', openMenu);
document.getElementById('closeMenuBtn').addEventListener('click', closeMenu);
menuOverlay.addEventListener('click', closeMenu);

// Socket Events
socket.on('device_list_updated', () => { fetchDevices(); });
socket.on('device_updated', (data) => { 
    const d = localDevices.find(x => x.id === data.id); 
    if(d) { d.state = data.state; renderDevices(); } 
});

socket.on('sensor_update', (data) => {
    if (data.type === 'humidity') {
        const humEl = document.getElementById('val-humidity');
        if (humEl) humEl.textContent = data.value + '%';
        dashboardStats.lastHum = data.value;
    } 
    else if (data.type === 'temperature') {
        const tempEl = document.getElementById('val-temperature');
        if (tempEl) tempEl.textContent = data.value + '°C';
        dashboardStats.lastTemp = data.value;
    } 
    else if (data.type === 'gas') {
        const gasEl = document.getElementById('val-gas');
        if (gasEl) {
            if (data.value === 'DANGER') {
                const dangerText = dictionary[currentLang]['danger'] || 'Nguy hiểm';
                gasEl.textContent = dangerText;
                gasEl.className = 'sensor-val text-danger';
                dashboardStats.lastGas = dangerText;
            } else {
                const safeText = dictionary[currentLang]['safe'] || 'An toàn';
                gasEl.textContent = safeText;
                gasEl.className = 'sensor-val safe';
                dashboardStats.lastGas = safeText;
            }
        }
    }

    const now = new Date();
    const hh = now.getHours().toString().padStart(2, '0');
    const mm = now.getMinutes().toString().padStart(2, '0');
    dashboardStats.lastUpdateText = `Cập nhật gần nhất lúc ${hh}:${mm}`;
    renderQuickStats();
});

// Khởi chạy
checkAuth();
