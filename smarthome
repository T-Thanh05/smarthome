@app.route('/api/devices', methods=['POST'])
def add_device():
    data = request.json
    name = data.get('name')
    type_ = data.get('type')
    device_id = f"{type_}_{int(time.time() * 1000)}"
    state = 'CLOSED' if type_ == 'door' else 'OFF'
    with get_conn() as conn:
        cur = conn.cursor()
        cur.execute("INSERT INTO devices (id, name, type, state) VALUES (%s, %s, %s, %s)", (device_id, name, type_, state))
        conn.commit()
    socketio.emit('device_list_updated')
    return jsonify(success=True)

@app.route('/api/devices/<device_id>', methods=['DELETE'])
def remove_device(device_id):
    with get_conn() as conn:
        cur = conn.cursor()
        cur.execute("DELETE FROM devices WHERE id = %s", (device_id,))
        conn.commit()
    socketio.emit('device_list_updated')
    return jsonify(success=True)

@socketio.on('toggle_device')
def handle_toggle_device(data):
    device_id = data.get('id')
    new_state = data.get('state')
    try:
        with get_conn() as conn:
            cur = conn.cursor()
            cur.execute("UPDATE devices SET state = %s WHERE id = %s", (new_state, device_id))
            conn.commit()
        socketio.emit('device_updated', data)
        
        topic = f"{MQTT_TOPIC_PREFIX}{device_id}"
        mqtt_client.publish(topic, new_state)
    except Exception as e:
        print("Lỗi toggle_device:", e)

