<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title data-i18n="title">Smart Home</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="style.css">
</head>
<body class="light-mode">
    <div class="glass-background"></div>

    <div id="loginScreen" class="login-overlay">
        <div class="card login-box">
            <div class="logo-icon" style="margin: 0 auto 15px; width: max-content;"><i class="fas fa-satellite-dish"></i></div>
            
            <form id="formLogin" onsubmit="event.preventDefault(); submitLogin();">
                <h2 data-i18n="loginTitle">Đăng Nhập</h2>
                <input type="text" id="loginUsername" placeholder="Tên đăng nhập" required>
                <input type="password" id="loginPassword" placeholder="Mật khẩu" required>
                <p id="loginMsg" class="msg-text"></p>
                <button type="submit" class="btn-save" style="width: 100%; margin-top: 15px;">Đăng Nhập</button>
                <div class="auth-links">
                    <a href="#" onclick="toggleAuth('register')">Đăng ký tài khoản</a> | 
                    <a href="#" onclick="toggleAuth('forgot')">Quên mật khẩu?</a>
                </div>
            </form>

            <form id="formRegister" style="display: none;" onsubmit="event.preventDefault(); submitRegister();">
                <h2>Đăng Ký Tài Khoản</h2>
                <input type="text" id="regUsername" placeholder="Tên đăng nhập mới" required>
                <input type="password" id="regPassword" placeholder="Mật khẩu" required>
                <input type="password" id="regRePassword" placeholder="Nhập lại mật khẩu" required>
                <p id="regMsg" class="msg-text"></p>
                <button type="submit" class="btn-save" style="width: 100%; margin-top: 15px; background: var(--success);">Đăng Ký</button>
                <div class="auth-links">
                    <a href="#" onclick="toggleAuth('login')"><i class="fas fa-arrow-left"></i> Quay lại Đăng nhập</a>
                </div>
            </form>

            <form id="formForgot" style="display: none;" onsubmit="event.preventDefault(); submitForgot();">
                <h2>Khôi Phục Mật Khẩu</h2>
                <p style="font-size:12px; color:var(--text-sub);">Nhập tên tài khoản của bạn để đặt lại mật khẩu mới.</p>
                <input type="text" id="forgotUsername" placeholder="Tên đăng nhập của bạn" required>
                <input type="password" id="forgotNewPassword" placeholder="Mật khẩu mới" required>
                <p id="forgotMsg" class="msg-text"></p>
                <button type="submit" class="btn-save" style="width: 100%; margin-top: 15px; background: #f39c12;">Đặt Lại Mật Khẩu</button>
                <div class="auth-links">
                    <a href="#" onclick="toggleAuth('login')"><i class="fas fa-arrow-left"></i> Quay lại Đăng nhập</a>
                </div>
            </form>
        </div>
    </div>

    <div id="appContainer" style="display: none;">
        <div class="container">
            <header>
                <div class="logo-container">
                    <div class="logo-icon"><i class="fas fa-satellite-dish"></i></div>
                    <div class="logo-text">
                        <h1 data-i18n="header">SMART HOME</h1>
                        <p class="subtitle">
                            Chào, <strong id="displayUsername" style="color:var(--primary)">...</strong>! 
                            (<span id="displayRole"></span>)
                        </p>
                        <div class="subtitle-row">
                            <span class="sub-badge sub-badge-primary">
                                <i class="fas fa-user-shield"></i> Personal Control • Enterprise UX
                            </span>
                            <span class="sub-badge sub-badge-soft">
                                <i class="fas fa-cloud"></i> Local Runtime
                            </span>
                        </div>
                    </div>
                </div>
                <div class="controls">
                    <button id="addDeviceBtn" class="btn-icon add-btn" onclick="document.getElementById('addModal').classList.add('active')">
                        <i class="fas fa-plus"></i> <span data-i18n="addDevice">Thêm thiết bị</span>
                    </button>
                    <button id="langToggle" class="btn-icon"><i class="fas fa-language"></i> EN | VI</button>
                    <button id="themeToggle" class="btn-icon" title="Light / Dark">
                        <i class="fas fa-moon"></i>
                    </button>
                    <button id="menuToggle" class="btn-icon" title="Menu">
                        <i class="fas fa-bars"></i>
                    </button>
                </div>
            </header>

            <section class="quick-stats" aria-label="Tổng quan hệ thống">
                <div class="stat-card">
                    <div class="stat-label">Tổng thiết bị</div>
                    <div class="stat-value" id="stat-total-devices">--</div>
                    <div class="stat-sub" id="stat-total-breakdown">Cửa: -- • Đèn: --</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Tình trạng hiện tại</div>
                    <div class="stat-value" id="stat-live-state">--</div>
                    <div class="stat-sub" id="stat-live-sub">Đèn bật: -- • Cửa mở: --</div>
                </div>
                <div class="stat-card stat-card-sensors">
                    <div class="stat-label">Cảm biến</div>
                    <div class="stat-sensor-row">
                        <span><i class="fas fa-temperature-half"></i> <span id="stat-temp">--°C</span></span>
                        <span><i class="fas fa-droplet"></i> <span id="stat-hum">--%</span></span>
                        <span><i class="fas fa-fire"></i> <span id="stat-gas">--</span></span>
                    </div>
                    <div class="stat-sub" id="stat-last-update">Chưa có dữ liệu thời gian thực</div>
                </div>
            </section>

            <main id="mainView">
                
                <div id="tab-dashboard" class="tab-content" style="display: block;">
                    <div class="dashboard">
                        <section class="card"><div class="card-header"><i class="fas fa-door-open icon-title"></i><h2 data-i18n="doors">Cửa</h2></div><div id="doors-container"></div></section>
                        <section class="card"><div class="card-header"><i class="fas fa-lightbulb icon-title"></i><h2 data-i18n="lights">Đèn</h2></div><div id="lights-container"></div></section>
                        <section class="card card-sensor">
                            <div class="card-header"><i class="fas fa-microchip icon-title"></i><h2 data-i18n="sensors">Cảm biến</h2></div>
                            <div class="device"><span><i class="fas fa-temperature-half" style="color: #ff3333;"></i> <span data-i18n="temperature">Nhiệt độ</span></span><strong class="sensor-val" id="val-temperature">--°C</strong></div>
                            <div class="device"><span><i class="fas fa-droplet" style="color: #0088cc;"></i> <span data-i18n="humidity">Độ ẩm</span></span><strong class="sensor-val" id="val-humidity">--%</strong></div>
                            <div class="device"><span><i class="fas fa-fire" style="color: #ff7300;"></i> <span data-i18n="gas">Khí Gas</span></span><strong class="sensor-val safe" id="val-gas" data-i18n="safe">--</strong></div>
                        </section>
                    </div>
                </div>

                <div id="tab-history" class="tab-content" style="display: none;">
                    <section class="card" style="width: 100%;">
                        <div class="card-header flex justify-between" style="display: flex; justify-content: space-between; align-items: center;">
                            <div><i class="fas fa-database icon-title"></i><h2>Truy xuất Lịch sử DB</h2></div>
                            <button class="btn-save" onclick="loadHistoryData()" style="padding: 8px 15px; width: auto; font-size: 13px;"><i class="fas fa-sync"></i> Tải lại</button>
                        </div>
                        <div style="overflow-x: auto; margin-top: 15px; max-height: 400px; border-radius: 10px; border: 1px solid rgba(128,128,128,0.2);">
                            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                                <thead style="background: rgba(128,128,128,0.1);">
                                    <tr>
                                        <th style="padding: 12px; border-bottom: 2px solid rgba(128,128,128,0.3);">ID</th>
                                        <th style="padding: 12px; border-bottom: 2px solid rgba(128,128,128,0.3);">Cảm Biến</th>
                                        <th style="padding: 12px; border-bottom: 2px solid rgba(128,128,128,0.3);">Giá Trị</th>
                                        <th style="padding: 12px; border-bottom: 2px solid rgba(128,128,128,0.3);">Thời Gian</th>
                                    </tr>
                                </thead>
                                <tbody id="history-table-body">
                                    <tr><td colspan="4" style="text-align:center; padding: 20px;">Đang tải dữ liệu...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </section>
                </div>

                <div id="tab-schedule" class="tab-content" style="display: none;">
                    <div class="dashboard">
                        <section class="card">
                            <div class="card-header">
                                <i class="fas fa-clock icon-title"></i><h2 data-i18n="menuSchedules">Tạo Lịch Hẹn Giờ</h2>
                            </div>
                            <p style="color: var(--text-sub); margin-bottom: 20px; font-size: 14px;">Thiết lập tự động bật/tắt thiết bị theo thời gian thực.</p>
                            
                            <label style="font-size: 14px; font-weight: bold; display: block; margin-bottom: 8px;">Chọn thiết bị:</label>
                            <select id="scheduleDevice" style="width: 100%; padding: 12px; border-radius: 10px; border: 1px solid rgba(128,128,128,0.3); background: rgba(255,255,255,0.5); margin-bottom: 15px;"></select>
                            
                            <div style="display: flex; gap: 15px;">
                                <div style="flex: 1;">
                                    <label style="font-size: 14px; font-weight: bold; display: block; margin-bottom: 8px;">Giờ kích hoạt:</label>
                                    <input type="time" id="scheduleTime" style="width: 100%; padding: 11px; border-radius: 10px; border: 1px solid rgba(128,128,128,0.3); background: rgba(255,255,255,0.5);">
                                </div>
                                <div style="flex: 1;">
                                    <label style="font-size: 14px; font-weight: bold; display: block; margin-bottom: 8px;">Hành động:</label>
                                    <select id="scheduleAction" style="width: 100%; padding: 12px; border-radius: 10px; border: 1px solid rgba(128,128,128,0.3); background: rgba(255,255,255,0.5);">
                                        <option value="ON">Bật / Mở</option>
                                        <option value="OFF">Tắt / Đóng</option>
                                    </select>
                                </div>
                            </div>
                            <button class="btn-save" style="width: 100%; margin-top: 25px; padding: 14px; border-radius: 10px; font-size: 15px;" onclick="saveSchedule()"><i class="fas fa-save"></i> Lưu lịch hẹn</button>
                        </section>
                        
                        <section class="card">
                            <div class="card-header">
                                <i class="fas fa-list icon-title"></i><h2>Danh sách đã hẹn</h2>
                            </div>
                            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: calc(100% - 60px); color: var(--text-sub); opacity: 0.6;">
                                <i class="fas fa-calendar-check" style="font-size: 48px; margin-bottom: 15px;"></i>
                                <p>Hệ thống tự động kích hoạt ngầm.</p>
                            </div>
                        </section>
                    </div>
                </div>

                <div id="tab-scenes" class="tab-content" style="display: none;">
                    <div class="card-header" style="margin-bottom: 25px;">
                        <i class="fas fa-layer-group icon-title"></i><h2 data-i18n="menuScenes" style="font-size: 24px;">Ngữ cảnh thông minh</h2>
                    </div>
                    <div class="dashboard" style="grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));">
                        <section class="card" style="cursor: pointer; text-align: center; padding: 40px 20px; transition: 0.3s; border: 2px solid transparent;" onmouseover="this.style.borderColor='var(--danger)'" onmouseout="this.style.borderColor='transparent'" onclick="activateScene('leave')">
                            <i class="fas fa-sign-out-alt text-danger" style="font-size: 48px; margin-bottom: 20px;"></i>
                            <h3 style="margin: 0 0 10px 0; font-size: 20px;">Ra khỏi nhà</h3>
                            <p style="font-size: 14px; color: var(--text-sub); line-height: 1.5;" data-i18n="sceneLeaveDesc">Tắt hết đèn, khóa tất cả cửa.</p>
                        </section>
                        
                        <section class="card" style="cursor: pointer; text-align: center; padding: 40px 20px; transition: 0.3s; border: 2px solid transparent;" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='transparent'" onclick="activateScene('sleep')">
                            <i class="fas fa-moon text-primary" style="font-size: 48px; margin-bottom: 20px;"></i>
                            <h3 style="margin: 0 0 10px 0; font-size: 20px;">Đi ngủ</h3>
                            <p style="font-size: 14px; color: var(--text-sub); line-height: 1.5;" data-i18n="sceneSleepDesc">Khóa cửa, tắt đèn, an tâm ngủ ngon.</p>
                        </section>
                        
                        <section class="card" style="cursor: pointer; text-align: center; padding: 40px 20px; transition: 0.3s; border: 2px dashed rgba(128,128,128,0.3); background: rgba(128,128,128,0.02);" onclick="alert('Tính năng đang phát triển!')">
                            <i class="fas fa-plus" style="font-size: 48px; margin-bottom: 20px; color: var(--text-sub);"></i>
                            <h3 style="margin: 0 0 10px 0; font-size: 20px; color: var(--text-sub);">Thêm Ngữ cảnh</h3>
                            <p style="font-size: 14px; color: var(--text-sub); line-height: 1.5;">Tạo kịch bản tự động mới.</p>
                        </section>
                    </div>
                </div>

                <div id="tab-settings" class="tab-content" style="display: none;">
                    <div class="dashboard">
                        <section class="card">
                            <div class="card-header">
                                <i class="fas fa-sliders-h icon-title"></i><h2 data-i18n="menuSettings">Cấu hình Thiết bị</h2>
                            </div>
                            <div style="margin-bottom: 20px;">
                                <div style="display: flex; justify-content: space-between; padding: 15px 0; border-bottom: 1px solid rgba(128,128,128,0.1); align-items: center;">
                                    <div>
                                        <strong style="display: block; font-size: 16px;">Âm báo rò rỉ Gas</strong>
                                        <span style="font-size: 12px; color: var(--text-sub);">Còi hú khi phát hiện khí Gas</span>
                                    </div>
                                    <label class="switch"><input type="checkbox" checked><span class="slider"></span></label>
                                </div>
                                <div style="padding: 15px 0;">
                                    <label style="font-size: 14px; font-weight: bold; display: block; margin-bottom: 8px;">IP Máy chủ (ESP32):</label>
                                    <input type="text" value="192.168.1.100" style="width: 100%; padding: 12px; border-radius: 10px; border: 1px solid rgba(128,128,128,0.3); background: rgba(255,255,255,0.5);">
                                </div>
                            </div>
                        </section>

                        <section class="card">
                            <div class="card-header">
                                <i class="fas fa-shield-alt icon-title" style="color: #f39c12;"></i><h2>Bảo mật Tài khoản</h2>
                            </div>
                            <p style="color: var(--text-sub); margin-bottom: 20px; font-size: 14px;">Đổi mật khẩu bảo mật để bảo vệ quyền truy cập hệ thống.</p>
                            
                            <input type="password" id="changeOldPass" placeholder="Mật khẩu hiện tại" style="width: 100%; padding: 12px; margin-bottom: 15px; border-radius: 10px; border: 1px solid rgba(128,128,128,0.3); background: rgba(255,255,255,0.5);">
                            <input type="password" id="changeNewPass" placeholder="Mật khẩu mới" style="width: 100%; padding: 12px; margin-bottom: 15px; border-radius: 10px; border: 1px solid rgba(128,128,128,0.3); background: rgba(255,255,255,0.5);">
                            <p id="changePassMsg" class="msg-text"></p>
                            <button onclick="submitChangePass()" class="btn-save" style="width: 100%; padding: 14px; border-radius: 10px; font-size: 15px;"><i class="fas fa-key"></i> Cập nhật mật khẩu</button>
                        </section>
                    </div>
                </div>

                <div id="tab-users" class="tab-content" style="display: none;">
                    <section class="card" style="width: 100%;">
                        <div class="card-header">
                            <i class="fas fa-users icon-title"></i><h2>Quản lý Người dùng</h2>
                        </div>
                        <p style="color: var(--text-sub); margin-bottom: 20px;">Cấp quyền hoặc xóa tài khoản của thành viên trong hệ thống.</p>
                        
                        <div style="background: rgba(128,128,128,0.05); padding: 20px; border-radius: 15px; border: 1px solid rgba(128,128,128,0.1);">
                            <div id="usersListContainer" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 15px;">
                                </div>
                        </div>
                    </section>
                </div>

            </main>
        </div>

        <div id="menuOverlay" class="menu-overlay"></div>
        <nav id="sideMenu" class="side-menu">
            <div class="menu-header">
                <h2 data-i18n="menuTitle">Danh mục</h2>
                <button id="closeMenuBtn" class="btn-icon"><i class="fas fa-times"></i></button>
            </div>
            <ul class="menu-links">
                <li><a href="#" id="menu-dashboard" class="active" onclick="switchTab('dashboard')"><i class="fas fa-home"></i> <span data-i18n="menuDashboard">Bảng điều khiển</span></a></li>
                <li><a href="#" id="menu-history" onclick="switchTab('history')"><i class="fas fa-database"></i> <span>Lịch sử Dữ liệu</span></a></li>
                <li><a href="#" id="menu-schedule" onclick="switchTab('schedule')"><i class="fas fa-clock"></i> <span data-i18n="menuSchedules">Lịch hẹn giờ</span></a></li>
                <li><a href="#" id="menu-scenes" onclick="switchTab('scenes')"><i class="fas fa-layer-group"></i> <span data-i18n="menuScenes">Ngữ cảnh</span></a></li>
                <li><a href="#" id="menu-settings" onclick="switchTab('settings')"><i class="fas fa-cog"></i> <span data-i18n="menuSettings">Cài đặt</span></a></li>
                
                <hr style="border: 0; border-top: 1px solid rgba(128,128,128,0.2); margin: 15px 20px;">
                <li id="menuManageUsersLi" style="display: none;">
                    <a href="#" id="menu-users" onclick="switchTab('users')"><i class="fas fa-users" style="color: var(--primary);"></i> Quản lý Người dùng</a>
                </li>
                <li><a href="#" onclick="logout()" style="color: var(--danger);"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a></li>
            </ul>
        </nav>

        <div id="addModal" class="modal">
            <div class="modal-content card" style="width: 320px;">
                <div class="modal-header"><h3 data-i18n="addNewTitle">Thêm thiết bị mới</h3></div>
                <input type="text" id="newDevName" placeholder="Tên thiết bị..." style="width: 100%; padding: 12px; margin-bottom: 15px; border-radius: 10px; border: 1px solid rgba(128,128,128,0.3); background: rgba(255,255,255,0.5);">
                <select id="newDevType" style="width: 100%; padding: 12px; margin-bottom: 20px; border-radius: 10px; border: 1px solid rgba(128,128,128,0.3); background: rgba(255,255,255,0.5);">
                    <option value="light">Đèn chiếu sáng</option>
                    <option value="door">Cửa / Khóa</option>
                </select>
                <div class="modal-actions">
                    <button onclick="submitNewDevice()" class="btn-save" data-i18n="save">Lưu</button>
                    <button onclick="document.getElementById('addModal').classList.remove('active')" class="btn-cancel" data-i18n="cancel">Hủy</button>
                </div>
            </div>
        </div>

    </div>

    <script src="https://cdn.socket.io/4.8.1/socket.io.min.js"></script>
    <script src="lang.js"></script>
    <script src="script.js"></script>
</body>
</html>
